# Copy to `.env.test` for local Playwright e2e runs (`.env.test` is gitignored).
#
# The suite authors data (users, media, stages), so it must point at the
# DISPOSABLE e2e backend, never the shared dev DB (global-setup refuses the
# known shared endpoints unless E2E_ALLOW_SHARED_DB=1). Standard flow:
#
#   tests/e2e/env/e2e-backend-up.sh     # fresh upstage_e2e DB + API on 127.0.0.1:9092
#   tests/e2e/env/vite-e2e.sh           # SPA on 127.0.0.1:3001 pointed at it
#   E2E_SKIP_CONFIRM=1 PWHEADLESS=1 pnpm e2e
#   tests/e2e/env/e2e-backend-down.sh   # dispose (drops the DB)
#
# Prerequisites:
#   • Docker with the dev stack images/containers (postgres_container_dev,
#     mosquitto_container_dev, image upstage/backend:dev).
#   • SPA already running at E2E_BASE_URL (Playwright never starts Vite).
#   • Mosquitto WS on E2E_MQTT_HOST:E2E_MQTT_PORT (docker dev: localhost:9001).

E2E_BASE_URL=http://127.0.0.1:3001
E2E_GRAPHQL_ENDPOINT=http://127.0.0.1:9092/api/studio_graphql
E2E_MQTT_HOST=localhost
E2E_MQTT_PORT=9001
# The e2e backend's migrations seed the super admin as admin / Secret@123.
E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=NNNNNNNNNN
E2E_PLAYER_PASSWORD=NNNNNNNNNNN
# Optional: Cloudflare Turnstile token for Node-side GraphQL login (global-setup).
# Only read by tests/e2e — never used by the SPA. Tokens expire quickly; omit to
# let global-setup fall back to browser login when the SPA renders Turnstile
# (VITE_ENV_TYPE=Production on the dev server).
# E2E_CAPTCHA_TOKEN=
E2E_SKIP_CONFIRM=1

# Copy to `.env.test` for local Playwright e2e runs (`.env.test` is gitignored).
#
# Prerequisites:
#   • Studio API reachable at E2E_GRAPHQL_ENDPOINT (docker dev: port 9090).
#   • SPA already running at E2E_BASE_URL (Playwright never starts Vite).
#   • Mosquitto WS on E2E_MQTT_HOST:E2E_MQTT_PORT (docker dev: localhost:9001).
#
# If port 3000 is occupied by the API container, start Vite on another port, e.g.:
#   LOCAL_SERVE_STATIC_CONTENT=/app_code_dev/uploads \
#   VITE_GRAPHQL_ENDPOINT=http://127.0.0.1:9090/api/ \
#   pnpm exec vite --port 5173 --host

E2E_BASE_URL=http://127.0.0.1:5173
E2E_GRAPHQL_ENDPOINT=http://127.0.0.1:9090/api/studio_graphql
E2E_MQTT_HOST=localhost
E2E_MQTT_PORT=9001
E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=Secret@123
E2E_PLAYER_PASSWORD=Secret@123
E2E_SKIP_CONFIRM=1

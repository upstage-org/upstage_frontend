# Compose-time interpolation only. Distinct from the Vite `.env` in this dir
# (which the frontend bundle reads at build time). Passed to docker compose via
# `--env-file .env.compose` from run_front_end_*.sh.
# Populated by those scripts at launch (`export HOST_UID=$(id -u)`); kept as a
# committable fallback so a fresh checkout still resolves to a sane non-zero
# UID/GID.
HOST_UID=1000
HOST_GID=1000

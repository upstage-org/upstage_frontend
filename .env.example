# Copy to `.env` and adjust. Vite injects VITE_* at build / dev.
#
# GraphQL: use the SAME host/port as the Vite dev app (e.g. :3000), path `/api/`.
# The dev server proxies `/api` to the studio API (see `vite.config.ts`).
# Never set this to :3001 for the SPA — the browser would bypass the proxy.
# Leave unset to use `window.location.origin` + `/api/` (see `src/config.ts`).

VITE_GRAPHQL_ENDPOINT=http://localhost:3000/api/
VITE_STATIC_ASSETS_ENDPOINT=/resources/
VITE_MQTT_NAMESPACE=dev
VITE_MQTT_ENDPOINT=ws://localhost:9001
VITE_MQTT_USERNAME=
VITE_MQTT_PASSWORD=
VITE_JITSI_ENDPOINT=http://localhost/
VITE_CLOUDFLARE_CAPTCHA_SITEKEY=
VITE_STRIPE_KEY=
VITE_RELEASE_VERSION=2026.05.05
VITE_ALIAS_RELEASE_VERSION=84a231c
VITE_ENV_TYPE=dev

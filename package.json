    "less": "^4.1.2",
    "lodash": "^4.17.21",
    "modern-copy": "^1.0.3",
    "moveable": "^0.24.5",
    "mqtt": "^4.2.6",
    "object-hash": "^2.1.1",
    "pinia": "^2.2.4",
    "pinia-plugin-persistedstate": "^3.2.1",
    "qr-code-styling": "1.9.2",
    "uuid": "^9.0.1",
    "vue": "3.5.13",
    "vue-i18n": "^9.5.0",
    "vue-router": "4",

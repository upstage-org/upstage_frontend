    "@tiptap/starter-kit": "2.12.0",
    "@tiptap/vue-3": "2.12.0",
    "@vue/apollo-composable": "4.2.2",
    "@vue/runtime-core": "3.5.13",
    "@vueuse/core": "13.1.0",
    "@yeger/vue-masonry-wall": "5.0.18",
    "animejs": "4.0.2",
    "ant-design-vue": "^4.2.1",
    "axios": "1.9.0",

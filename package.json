  "scripts": {
    "serve": "vite --port=3000 --host",
    "dev": "vite --port=3000 --host",
    "build": "vue-tsc --noEmit --skipLibCheck && vite build",
    "build:dev": "vue-tsc --noEmit --skipLibCheck && vite build --mode development",
    "serve:dist": "vite preview",
    "i18n": "node ./src/i18n/scan.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"./*.{js,ts,vue,json,md}\" \"./src/**/*.{js,ts,vue,json}\" \"./tests/**/*.{js,ts}\"",
    "format:check": "prettier --check \"./*.{js,ts,vue,json,md}\" \"./src/**/*.{js,ts,vue,json}\" \"./tests/**/*.{js,ts}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "e2e": "pnpm exec tsx ./tests/e2e/run-e2e.ts test",
    "e2e:assets": "node tests/e2e/assets/generate.mjs",
    "e2e:setup": "pnpm exec tsx ./tests/e2e/run-e2e.ts test --project=setup",
    "e2e:perform": "pnpm exec tsx ./tests/e2e/run-e2e.ts test --project=perform",
    "e2e:perform:rehearsal": "E2E_PHASES=rehearsal pnpm exec tsx ./tests/e2e/run-e2e.ts test --project=perform",
    "e2e:perform:live": "E2E_PHASES=live pnpm exec tsx ./tests/e2e/run-e2e.ts test --project=perform",
    "e2e:perform:replay": "E2E_PHASES=replay pnpm exec tsx ./tests/e2e/run-e2e.ts test --project=perform",
    "e2e:features": "pnpm exec tsx ./tests/e2e/run-e2e.ts test --project=features",
    "e2e:smoke": "E2E_BEATS=smoke pnpm exec tsx ./tests/e2e/run-e2e.ts test --project=perform",
    "e2e:smoke:stub": "pnpm exec tsx ./tests/e2e/run-e2e.ts test --project=smoke --grep @smoke",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "depcheck": "depcheck --ignores=\"@types/*,eslint-*,@vue/eslint-config-*,@typescript-eslint/*,vue-eslint-parser,jsdom,postcss,autoprefixer,vite-tsconfig-paths,@playwright/test,@vitest/ui,@vue/test-utils,@graphql-codegen/*\"",
    "serve:localhost": "vite --mode localhost --port=3000"
  },

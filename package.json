    "prettier": "^3.3.3",
    "sass": "^1.26.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "28.5.0",
    "vite": "6.3.5",
    "vite-plugin-vue-devtools": "^7.6.0",
